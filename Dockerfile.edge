FROM golang:alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o edge ./cmd/edge

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app
COPY --from=builder /build/edge .

RUN mkdir -p /app/data
VOLUME ["/app/data"]
EXPOSE 8080

CMD ["./edge"]
