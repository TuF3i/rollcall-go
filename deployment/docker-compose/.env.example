# 必填：IDS 账号密码
EDGE_USERNAME=your_ids_username
EDGE_PASSWORD=your_ids_password

# 课表 API（学号替换）
EDGE_CURRICULUM_API=https://cqupt.ishub.top/api/curriculum/YOUR_STUDENT_ID/curriculum.json

# Center 服务器
EDGE_CENTER_SERVER_URL=wss://cqupt.ishub.top/api/rollcall/ws
EDGE_CENTER_SERVER_SECRET=

# 自动定位签到
EDGE_AUTO_LOCATION_CHECKIN=true

# 自动数字签到（默认开启）
EDGE_AUTO_NUMBER_CHECKIN=true

# Telegram 通知（可选）
TG_BOT_TOKEN=
TG_CHAT_ID=
