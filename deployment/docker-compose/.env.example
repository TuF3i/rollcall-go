# 必填：IDS 账号密码
EDGE_USERNAME=your_ids_username
EDGE_PASSWORD=your_ids_password

# 课表 API（学号替换）
EDGE_CURRICULUM_API=https://cqupt.ishub.top/api/curriculum/YOUR_STUDENT_ID/curriculum.json
EDGE_CURRICULUM_PRE_MINUTES=10

# HTTP 端口（默认 8080，设为空字符串可禁用）
EDGE_HTTP_PORT=8080

# Center 服务器
EDGE_CENTER_SERVER_URL=wss://cqupt.ishub.top/api/rollcall/ws
EDGE_CENTER_SERVER_SECRET=

# 自动定位签到
EDGE_AUTO_LOCATION_CHECKIN=true

# 自动数字签到（默认开启）
EDGE_AUTO_NUMBER_CHECKIN=true

# 签到轮询间隔（秒）
POLL_DELAY=30

# Etcd 服务注册（可选，留空禁用）
EDGE_ETCD_ENDPOINTS=
EDGE_ETCD_PREFIX=/rollcall

# API 模式：http 或 rpc（默认 http）
EDGE_API_MODE=http
EDGE_RPC_PORT=8888

# Telegram 通知（可选）
TG_BOT_TOKEN=
TG_CHAT_ID=
